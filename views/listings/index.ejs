<% layout("/layouts/boilerplate") %>
<div id="filters">
    <a href="/listings?category=Trending" style="text-decoration: none; color: inherit;">
        <div class="filter">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
        </div>
    </a>
    <a href="/listings?category=Rooms" style="text-decoration: none; color: inherit;">
        <div class="filter">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Rooms</p>
        </div>
    </a>
    <a href="/listings?category=Iconic Cities" style="text-decoration: none; color: inherit;">
        <div class="filter">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic Cities</p>
        </div>
    </a>
    <a href="/listings?category=Mountains" style="text-decoration: none; color: inherit;">
        <div class="filter">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mountains</p>
        </div>
    </a>
    <a href="/listings?category=Castles" style="text-decoration: none; color: inherit;">
        <div class="filter">
            <div><i class="fa-solid fa-fort-awesome"></i></div>
            <p>Castles</p>
        </div>
    </a>
    <a href="/listings?category=Amazing Pools" style="text-decoration: none; color: inherit;">
        <div class="filter">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Amazing Pools</p>
        </div>
    </a>
    <a href="/listings?category=Camping" style="text-decoration: none; color: inherit;">
        <div class="filter">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
        </div>
    </a>
    <a href="/listings?category=Farms" style="text-decoration: none; color: inherit;">
        <div class="filter">
            <div><i class="fa-solid fa-cow"></i></div>
            <p>Farms</p>
        </div>
    </a>
    <a href="/listings?category=Arctic" style="text-decoration: none; color: inherit;">
        <div class="filter">
            <div><i class="fa-solid fa-snowflake"></i></div>
            <p>Arctic</p>
        </div>
    </a>
</div>

<div class="container mt-4">
  <% if (!allListings || allListings.length === 0) { %>
    <p class="text-center">No listings available for this category.</p>
  <% } else { %>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">
      <% for (let listing of allListings) { %>
        <div class="col">
          <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
            <div class="card h-100 shadow-sm">
              <img
                src="<%= listing.image?.url || listing.image || '/images/placeholder.jpg' %>"
                class="card-img-top"
                alt="listing_image"
              >
              <div class="card-body text-center">
                <p class="card-text mb-1">
                  <b><%= listing.title || "Untitled" %></b>
                </p>
                <p class="card-text mt-1">
                  ₹ <%= listing.price != null ? listing.price.toLocaleString("en-IN") : "0" %> / Night
                </p>
                <% if (listing.location || listing.country) { %>
                  <p class="text-muted mb-0">
                    <%= listing.location || listing.country %>
                  </p>
                <% } %>
              </div>
            </div>
          </a>
        </div>
      <% } %>
    </div>
  <% } %>
</div>
<br>
<br>